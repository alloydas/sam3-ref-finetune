+def make_wandb_logger(
+    project: str,
+    name: Optional[str] = None,
+    entity: Optional[str] = None,
+    group: Optional[str] = None,
+    dir: Optional[str] = None,
+    config: Optional[Dict[str, Any]] = None,
+    **init_kwargs: Any,
+):
+    """Factory for a Weights & Biases logger (rank-0 only)."""
+    if dir:
+        makedir(dir)
+    return WandbLogger(
+        project=project,
+        name=name,
+        entity=entity,
+        group=group,
+        dir=dir,
+        config=config,
+        **init_kwargs,
+    )
+
+
+class WandbLogger:
+    """A logger that forwards scalars to Weights & Biases.
+
+    Mirrors the TensorBoardLogger interface (log / log_dict / log_hparams) so the
+    Logger facade can drive both. Only rank 0 creates a run.
+    """
+
+    def __init__(
+        self,
+        project: str,
+        name: Optional[str] = None,
+        entity: Optional[str] = None,
+        group: Optional[str] = None,
+        dir: Optional[str] = None,
+        config: Optional[Dict[str, Any]] = None,
+        **init_kwargs: Any,
+    ) -> None:
+        _, self._rank = get_machine_local_and_dist_rank()
+        self._run = None
+        if self._rank == 0:
+            import wandb
+
+            self._run = wandb.init(
+                project=project,
+                name=name,
+                entity=entity,
+                group=group,
+                dir=dir,
+                config=config,
+                **init_kwargs,
+            )
+            logging.info(
+                f"wandb run initialized: {getattr(self._run, 'url', '(offline)')}"
+            )
+        atexit.register(self.close)
+
+    @staticmethod
+    def _scalar(v: Scalar) -> Scalar:
+        return v.item() if hasattr(v, "item") else v
+
+    def log(self, name: str, data: Scalar, step: int) -> None:
+        if self._run is None:
+            return
+        self._run.log({name: self._scalar(data)}, step=step)
+
+    def log_dict(self, payload: Dict[str, Scalar], step: int) -> None:
+        if self._run is None:
+            return
+        self._run.log({k: self._scalar(v) for k, v in payload.items()}, step=step)
+
+    def log_hparams(
+        self, hparams: Dict[str, Scalar], meters: Dict[str, Scalar]
+    ) -> None:
+        if self._run is None:
+            return
+        self._run.config.update(hparams, allow_val_change=True)
+        if meters:
+            self._run.log({k: self._scalar(v) for k, v in meters.items()})
+
+    def close(self) -> None:
+        if self._run is not None:
+            self._run.finish()
+            self._run = None
+
+
